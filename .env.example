# ===== 必須 =====
# Discord Bot のトークン（Discord Developer Portal → Bot → Reset Token）
DISCORD_TOKEN=

# ===== 推奨 =====
# 自分のサーバーID（指定するとコマンドが即時反映される）
GUILD_ID=

# ===== スプレッドシート連携（任意） =====
# Googleサービスアカウントの鍵ファイル
GOOGLE_CREDENTIALS_FILE=credentials.json
# 同期先スプレッドシートのID（URLの /d/ と /edit の間の文字列）
SPREADSHEET_ID=

# ===== 任意 =====
# 管理者以外で運営権限を与えるロール名
ADMIN_ROLE_NAME=運営

# tournament.json のファイル名
TOURNAMENT_FILE=tournament.json

# trueでtournament.json更新時にgit add/commit/pushを自動実行（GitHub Pages連携用）
GIT_AUTO_PUSH=false
# git操作するリポジトリのパス（省略時はbot.pyと同じ場所）
GIT_REPO_DIR=

# 結果未報告リマインド（分。0で無効）と通知先チャンネルID
REMINDER_MINUTES=0
REMINDER_CHANNEL_ID=
